# Backend server port
PORT=5000

# Use ONE MongoDB URI below for local development.
#
# Option A: MongoDB Atlas (recommended)
# 1) Replace <username>, <password>, and <cluster-url>
# 2) Keep retryWrites=true&w=majority
# 3) Use your own database name instead of react_mart
#
# Example cluster-url format:
# cluster0.xxxxx.mongodb.net
#
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/react_mart?retryWrites=true&w=majority

# Option B: Local MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/react_mart
